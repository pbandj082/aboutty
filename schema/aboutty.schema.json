{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aboutty.dev/schema/aboutty.schema.json",
  "title": "aboutty configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["steps"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "width": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "padding": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "fontSize": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "lineHeight": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "username": {
      "type": "string"
    },
    "usernameSeparator": {
      "type": "string"
    },
    "hostname": {
      "type": "string"
    },
    "cwdSeparator": {
      "type": "string"
    },
    "cwd": {
      "type": "string"
    },
    "prompt": {
      "type": "string"
    },
    "loop": {
      "type": "boolean"
    },
    "stepIntervalMs": {
      "type": "number",
      "minimum": 0
    },
    "typingIntervalMs": {
      "type": "number",
      "minimum": 0
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "background": { "type": "string" },
        "border": { "type": "string" },
        "title": { "type": "string" },
        "username": { "type": "string" },
        "usernameSeparator": { "type": "string" },
        "hostname": { "type": "string" },
        "cwdSeparator": { "type": "string" },
        "cwd": { "type": "string" },
        "prompt": { "type": "string" },
        "text": { "type": "string" },
        "command": { "type": "string" },
        "output": { "type": "string" },
        "separator": {
          "type": "string",
          "deprecated": true
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "text"],
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "const": "output" }
              },
              "required": ["type"]
            },
            "then": {
              "not": {
                "required": ["cwd"]
              }
            }
          }
        ],
        "properties": {
          "type": {
            "enum": ["command", "output"]
          },
          "text": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["value"],
                  "properties": {
                    "value": {
                      "type": "string",
                      "minLength": 1
                    },
                    "color": {
                      "type": "string"
                    },
                    "repeat": {
                      "type": "integer",
                      "minimum": 1
                    },
                    "repeatDelayMs": {
                      "type": "number",
                      "minimum": 0
                    },
                    "typingIntervalMs": {
                      "type": "number",
                      "minimum": 0
                    },
                    "bold": {
                      "type": "boolean"
                    },
                    "italic": {
                      "type": "boolean"
                    }
                  }
                }
              }
            ]
          },
          "cwd": {
            "type": "string"
          },
          "delayMs": {
            "type": "number",
            "minimum": 0
          },
          "typingIntervalMs": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    }
  }
}
