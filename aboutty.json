{
  "$schema": "./schema/aboutty.schema.json",
  "title": "aboutty repository",
  "username": "github",
  "usernameSeparator": "@",
  "hostname": "aboutty",
  "cwdSeparator": ":",
  "cwd": "~",
  "prompt": "$",
  "width": 880,
  "padding": 24,
  "fontSize": 14,
  "lineHeight": 22,
  "loop": true,
  "cursor": {
    "enabled": true,
    "style": "bar",
    "blinkIntervalMs": 600
  },
  "stepIntervalMs": 350,
  "typingIntervalMs": 28,
  "theme": {
    "background": "#101418",
    "border": "#2a3138",
    "title": "#d7dee6",
    "username": "#6ee7b7",
    "usernameSeparator": "#8bd5ca",
    "hostname": "#93c5fd",
    "cwdSeparator": "#7dd3fc",
    "cwd": "#a7f3d0",
    "prompt": "#5eead4",
    "text": "#f8fafc",
    "command": "#f8fafc",
    "output": "#cbd5e1",
    "cursor": "#f8fafc"
  },
  "steps": [
    {
      "type": "output",
      "typingIntervalMs": 0,
      "text": [
        {
          "color": "#6ee7b7",
          "value": "      ___.                  __    __          \n_____ \\_ |__   ____  __ ___/  |__/  |_ ___.__.\n\\__  \\ | __ \\ /  _ \\|  |  \\   __\\   __<   |  |\n / __ \\| \\_\\ (  <_> )  |  /|  |  |  |  \\___  |\n(____  /___  /\\____/|____/ |__|  |__|  / ____|\n     \\/    \\/                          \\/     "
        }
      ]
    },
    {
      "type": "command",
      "cwd": "~/aboutty",
      "text": "gh repo view pbandj082/aboutty --json stargazerCount,forkCount"
    },
    {
      "type": "output",
      "typingIntervalMs": 0,
      "text": [
        {
          "value": "repository       ",
          "color": "#94a3b8"
        },
        {
          "value": "pbandj082/aboutty\n",
          "color": "#93c5fd",
          "bold": true
        },
        {
          "value": "stars            ",
          "color": "#94a3b8"
        },
        {
          "value": "5\n",
          "color": "#facc15",
          "bold": true
        },
        {
          "value": "forks            ",
          "color": "#94a3b8"
        },
        {
          "value": "0\n",
          "color": "#c084fc",
          "bold": true
        },
        {
          "value": "open items       ",
          "color": "#94a3b8"
        },
        {
          "value": "0\n",
          "color": "#fb7185",
          "bold": true
        },
        {
          "value": "commits          ",
          "color": "#94a3b8"
        },
        {
          "value": "49\n",
          "color": "#6ee7b7",
          "bold": true
        },
        {
          "value": "default branch   ",
          "color": "#94a3b8"
        },
        {
          "value": "main\n",
          "color": "#93c5fd",
          "bold": true
        },
        {
          "value": "license          ",
          "color": "#94a3b8"
        },
        {
          "value": "MIT\n",
          "color": "#f8fafc",
          "bold": true
        },
        {
          "value": "packages         ",
          "color": "#94a3b8"
        },
        {
          "value": "core / cli / studio / action\n",
          "color": "#6ee7b7",
          "bold": true
        },
        {
          "value": "updated          ",
          "color": "#94a3b8"
        },
        {
          "value": "2026-06-25T15:55:00Z",
          "color": "#94a3b8",
          "bold": true
        }
      ]
    },
    {
      "type": "command",
      "cwd": "~/aboutty/apps/studio",
      "text": "pnpm build"
    },
    {
      "type": "output",
      "text": [
        {
          "value": "Building template-aware studio"
        },
        {
          "value": "...",
          "repeat": 3,
          "repeatDelayMs": 260,
          "typingIntervalMs": 140,
          "color": "#38bdf8"
        }
      ]
    },
    {
      "type": "output",
      "typingIntervalMs": 0,
      "text": "dist/index.html\nassets/index-[hash].js\nassets/index-[hash].css"
    },
    {
      "type": "command",
      "cwd": "~/aboutty",
      "text": "aboutty aboutty.json --out assets/aboutty.svg"
    },
    {
      "type": "output",
      "text": [
        {
          "value": "Rendering README terminal SVG"
        },
        {
          "value": "...",
          "repeat": 3,
          "repeatDelayMs": 280,
          "typingIntervalMs": 160,
          "color": "#6ee7b7"
        }
      ]
    },
    {
      "type": "output",
      "typingIntervalMs": 0,
      "text": "Generated assets/aboutty.svg"
    }
