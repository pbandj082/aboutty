{
  "name": "@aboutty/cli",
  "version": "0.2.0",
  "type": "module",
  "description": "Command line interface for generating aboutty SVG files.",
  "license": "MIT",
  "homepage": "https://github.com/pbandj082/aboutty#readme",
  "bugs": {
    "url": "https://github.com/pbandj082/aboutty/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pbandj082/aboutty.git",
    "directory": "packages/cli"
  },
  "bin": {
    "aboutty": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm --filter @aboutty/core build && rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @aboutty/core build && tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aboutty/core": "workspace:*"
  }
}
